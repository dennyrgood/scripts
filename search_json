#!/usr/bin/env python3
import json
import csv
import sys
import os

def find_nodes_recursive(data, target_type="PrimitiveStringMultiline"):
    results = []

    # If it's a list, check every item
    if isinstance(data, list):
        for item in data:
            results.extend(find_nodes_recursive(item, target_type))
    
    # If it's a dictionary, check the type and recurse into values
    elif isinstance(data, dict):
        if data.get("type") == target_type:
            # Found one! Extract the goods
            results.append({
                "id": data.get("id", "N/A"),
                "title": data.get("title", "No Title"),
                "widgets_values": "|".join(map(str, data.get("widgets_values", [])))
            })
        
        # Keep digging into the values of this dictionary
        for value in data.values():
            results.extend(find_nodes_recursive(value, target_type))
            
    return results

def main():
    if len(sys.argv) < 2:
        print("Usage: ./script.py input.json [output.csv]")
        return

    input_file = sys.argv[1]
    output_file = sys.argv[2] if len(sys.argv) > 2 else os.path.splitext(input_file)[0] + "_out.csv"

    try:
        with open(input_file, 'r', encoding='utf-8') as f:
            data = json.load(f)
        
        found_items = find_nodes_recursive(data)

        if not found_items:
            print("No nodes of type 'PrimitiveStringMultiline' were found.")
            return

        # Write to CSV
        keys = found_items[0].keys()
        with open(output_file, 'w', newline='', encoding='utf-8') as f:
            dict_writer = csv.DictWriter(f, fieldnames=keys)
            dict_writer.writeheader()
            dict_writer.writerows(found_items)

        print(f"Done! Found {len(found_items)} entries. Saved to {output_file}")

    except Exception as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()
